{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "ES2022",
    "target": "ES2022",
    "incremental": true,
    "tsBuildInfoFile": "./dist/.tsbuildinfo.esm",
    "declaration": true,
    "declarationDir": "./dist/types",
    "declarationMap": false,
    "stripInternal": true,
    "outDir": "./dist/esm",
    "noEmit": false,
    "noEmitOnError": true
  }
}
