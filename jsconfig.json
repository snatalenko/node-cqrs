{
    "compilerOptions": {
        "target": "es2022",
        "module": "commonjs",
        "moduleResolution": "node",
        "baseUrl": ".",
        "paths": {
            "node-cqrs": [
                "./types/index.d.ts"
            ],
            "node-cqrs/*": [
                "./types/*/index.d.ts"
            ]
        },
        "allowSyntheticDefaultImports": true,
        "checkJs": true,
        "resolveJsonModule": true,
        "lib": [
            "es2022",
            "dom"
        ]
    },
    "exclude": [
        "node_modules",
        "dist",
        "dist/**",
        "examples/**/bundle.js"
    ]
}
